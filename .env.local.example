# Arsenal Supporters Club Ghana — Environment Variables v7.0.0
# Copy to .env.local and fill in your values
# This version includes: Real Authentication, Membership Renewal, Admin Settings

# ── App Configuration ──────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Arsenal Supporters Club Ghana"
APP_VERSION=7.0.0

# ── Database Connection (MySQL 8.0+ / PostgreSQL 14+ / MariaDB 10.6+) ─────────
# 1. Create the database manually first:
#    MySQL: CREATE DATABASE arsenal_ghana_v7 CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
# 2. Import the schema from database/schema-v7.sql
# 3. Set the DATABASE_URL below
#
# MySQL Example:
DATABASE_URL=mysql://arsenal_user:%4019Zenisha87@localhost:3306/ascgh
#
# PostgreSQL Example:
# DATABASE_URL=postgresql://arsenal_user:strong_password_here@localhost:5432/ascgh

# ── JWT & Session Configuration ────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long
SESSION_SECRET=your-super-secret-session-key-min-32-characters-long
SESSION_MAX_AGE=2592000
NEXT_PUBLIC_SESSION_TIMEOUT_MINUTES=30

# ── Email (SMTP) Configuration ─────────────────────────────────────────────────
# Gmail Example:
# 1. Enable 2-factor authentication on your Google account
# 2. Create an app password at https://myaccount.google.com/apppasswords
# 3. Use the app password below (without spaces)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-google-app-password
SMTP_FROM_NAME=Arsenal Ghana
SMTP_FROM_EMAIL=noreply@arsenalgana.org

# ── SMS Configuration (Hubtel) ─────────────────────────────────────────────────
# Get credentials from https://hubtel.com
# For testing, you can use demo credentials provided by Hubtel
HUBTEL_CLIENT_ID=your-hubtel-client-id
HUBTEL_CLIENT_SECRET=your-hubtel-client-secret
HUBTEL_SENDER_NAME=ArsenalGH
NEXT_PUBLIC_SMS_ENABLED=true

# ── Social Login Configuration ─────────────────────────────────────────────────
# Google OAuth:
# 1. Go to https://console.cloud.google.com
# 2. Create a new project and enable Google+ API
# 3. Create OAuth 2.0 credentials (Web application)
# 4. Add authorized redirect URI: http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Facebook OAuth:
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# ── Payment Processing (Paystack) ──────────────────────────────────────────────
# Get API keys from https://dashboard.paystack.com
# Test keys start with: pk_test_ and sk_test_
# Live keys start with: pk_live_ and sk_live_
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your_test_public_key
PAYSTACK_SECRET_KEY=sk_test_your_test_secret_key

# ── File Upload & Storage (Cloudinary) ─────────────────────────────────────────
# Get credentials from https://cloudinary.com
# Sign up for free account for testing
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
NEXT_PUBLIC_MAX_FILE_SIZE_MB=10

# ── Two-Factor Authentication ──────────────────────────────────────────────────
NEXT_PUBLIC_2FA_ENABLED=true
NEXT_PUBLIC_2FA_PROVIDER=authenticator

# ── Security Headers ───────────────────────────────────────────────────────────
NEXT_PUBLIC_CORS_ORIGINS=http://localhost:3000
NEXT_PUBLIC_ENABLE_HTTPS_REDIRECT=false

# ── Membership Configuration ───────────────────────────────────────────────────
NEXT_PUBLIC_CURRENCY=GHS
NEXT_PUBLIC_REGISTRATION_START_DATE=2026-06-01
NEXT_PUBLIC_REGISTRATION_END_DATE=2026-08-31
NEXT_PUBLIC_RENEWAL_START_DATE=2026-05-01
NEXT_PUBLIC_RENEWAL_END_DATE=2026-05-31
NEXT_PUBLIC_RENEWAL_FEE=100
NEXT_PUBLIC_RENEWAL_DURATION_YEARS=2

# ── Logging & Monitoring ───────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FILE_PATH=./logs/app.log
NEXT_PUBLIC_SENTRY_DSN=optional-sentry-url-for-error-tracking

# ── Feature Flags ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_FEATURE_EMAIL_VERIFICATION=true
NEXT_PUBLIC_FEATURE_SMS_VERIFICATION=true
NEXT_PUBLIC_FEATURE_SOCIAL_LOGIN=true
NEXT_PUBLIC_FEATURE_MEMBERSHIP_RENEWAL=true

# ── Browser Storage Policy ─────────────────────────────────────────────────────
# NOTE: This application does NOT store sensitive data in browser localStorage
# or sessionStorage. All session data is stored server-side in secure cookies.
# This prevents XSS attacks and data theft from local storage compromise.
NEXT_PUBLIC_BROWSER_STORAGE_DISABLED=true
NEXT_PUBLIC_SECURE_COOKIES=true
NEXT_PUBLIC_HTTPONLY_COOKIES=true
NEXT_PUBLIC_SAMESITE_COOKIES=Strict

# ── Maintenance Mode ───────────────────────────────────────────────────────────
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=""
