# Arsenal Supporters Club Ghana — Environment Variables v6.0.0

# ── App ─────────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Arsenal Supporters Club Ghana"

# ── Database (MySQL) ────────────────────────────────────────────────
# IMPORTANT: '@' in password must be encoded as %40
DATABASE_URL="mysql://root:%4019Zenisha87@localhost:3306/ascgh"

# ── JWT & Session (server-side only) ────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long
SESSION_SECRET=your-super-secret-session-key-min-32-characters-long
SESSION_MAX_AGE=2592000

# ── Email (SMTP) ─────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-google-app-password
SMTP_FROM_NAME=Arsenal Ghana
SMTP_FROM_EMAIL=noreply@arsenalgana.org

# ── SMS (Hubtel) ─────────────────────────────────────────────────────
HUBTEL_CLIENT_ID=your-hubtel-client-id
HUBTEL_CLIENT_SECRET=your-hubtel-client-secret
HUBTEL_SENDER_NAME=ArsenalGH

# ── Payments (Paystack) ─────────────────────────────────────────────
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your_test_public_key
PAYSTACK_SECRET_KEY=sk_test_your_test_secret_key

# ── Social Login ─────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# ── Cloud Storage (Cloudinary) ──────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=dssap5icf
CLOUDINARY_API_KEY=784175438467323
CLOUDINARY_API_SECRET=--1oZxv-43K4qH-WZPunwWb-S9Q

# ── App Settings ─────────────────────────────────────────────────────
NEXT_PUBLIC_CURRENCY=GHS
NEXT_PUBLIC_MAX_FILE_SIZE_MB=10

# ── Feature Flags ────────────────────────────────────────────────────
NEXT_PUBLIC_FEATURE_EMAIL_VERIFICATION=true
NEXT_PUBLIC_FEATURE_SMS_VERIFICATION=true
NEXT_PUBLIC_FEATURE_SOCIAL_LOGIN=true
NEXT_PUBLIC_FEATURE_MEMBERSHIP_RENEWAL=true

# ── Admin login fallback (used only when no admin accounts exist in DB) ─
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password

# ── Security (server enforced) ───────────────────────────────────────
HTTPONLY_COOKIES=true
SECURE_COOKIES=false
SAMESITE_COOKIES=Strict

# ── Logging ──────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FILE_PATH=./logs/app.log

# ── Maintenance ─────────────────────────────────────────────────────
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=""